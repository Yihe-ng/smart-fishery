# 【开发】环境变量

# 应用部署基础路径（如部署在子目录 /admin，则设置为 /admin/）
VITE_BASE_URL = /

# 开发服务器端口
VITE_PORT = 3006

# API 请求基础路径（开发环境设置为 / 使用代理，生产环境设置为完整后端地址）
VITE_API_URL = /

# 代理目标地址（开发环境通过 Vite 代理转发请求到此地址，解决跨域问题）
VITE_API_PROXY_URL = http://127.0.0.1:8000

# 访问模式：frontend（前端控制）或 backend（后端控制）
VITE_ACCESS_MODE = frontend

# Delete console
VITE_DROP_CONSOLE = false